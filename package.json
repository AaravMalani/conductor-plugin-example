{
  "name": "conductor-plugin-example",
  "version": "0.0.1",
  "packageManager": "yarn@4.6.0",
  "description": "The example plugin for Conductor framework",
  "main": "dist/index.js",
  "scripts": {
    "build": "rollup -c",
    "watch": "rollup -cw",
    "lint": "eslint --concurrency=auto src",
    "format": "prettier --write \"**/*.{ts,tsx,json,js,mjs}\"",
    "format:ci": "prettier --list-different \"**/*.{ts,tsx,json,js,mjs}\"",
    "test": "jest",
    "test-coverage": "jest --coverage"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/source-academy/conductor-plugin-example.git"
  },
  "license": "ISC",
  "files": [
    "dist"
  ],
  "bugs": {
    "url": "https://github.com/source-academy/conductor-plugin-example/issues"
  },
  "homepage": "https://github.com/source-academy/conductor-plugin-example#readme",
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@rollup/plugin-typescript": "^12.3.0",
    "@sourceacademy/conductor": "^0.3.0",
    "@types/jest": "^30.0.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^30.3.0",
    "prettier": "^3.8.1",
    "rollup": "^4.59.0",
    "ts-jest": "^29.4.6",
    "tslib": "^2.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.1"
  }
}
